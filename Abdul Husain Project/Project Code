#include <stdio.h>
#include <stdlib.h>
#include <string.h>

struct Student {
    int rolstudentlNo;
    char name[50];
    int age;
    char course[30];
};

void addStudent(FILE *fp) {
    struct Student s;
    printf("Enter Roll Number: ");
    scanf("%d", &s.rollNo);
    printf("Enter Name: ");
    scanf(" %[^\n]", s.name);
    printf("Enter Age: ");
    scanf("%d", &s.age);
    printf("Enter Course: ");
    scanf(" %[^\n]", s.course);

    fwrite(&s, sizeof(struct Student), 1, fp);
    printf("Student added successfully!\n");
}

void displayStudents(FILE *fp) {
    struct Student s;
    rewind(fp);
    printf("\n--- Student Records ---\n");
    while (fread(&s, sizeof(struct Student), 1, fp)) {
        printf("Roll No: %d | Name: %s | Age: %d | Course: %s\n",
               s.rollNo, s.name, s.age, s.course);
    }
}

void searchStudent(FILE *fp, int rollNo) {
    struct Student s;
    rewind(fp);
    while (fread(&s, sizeof(struct Student), 1, fp)) {
        if (s.rollNo == rollNo) {
            printf("Student Found: Roll=%d, Name=%s, Age=%d, Course=%s\n",
                   s.rollNo, s.name, s.age, s.course);
            return;
        }
    }
    printf("Student with Roll No %d not found.\n", rollNo);
}

int main() {
    FILE *fp = fopen("students.dat", "rb+");
    if (fp == NULL) {
        fp = fopen("students.dat", "wb+");
        if (fp == NULL) {
            printf("Error opening file!\n");
            return 1;
        }
    }

    int choice, rollNo;
    do {
        printf("\n--- Student Info Menu ---\n");
        printf("1. Add Student\n");
        printf("2. Display Students\n");
        printf("3. Search Student\n");
        printf("4. Exit\n");
        printf("Enter choice: ");
        scanf("%d", &choice);

        switch (choice) {
            case 1: addStudent(fp); break;
            case 2: displayStudents(fp); break;
            case 3:
                printf("Enter Roll No to search: ");
                scanf("%d", &rollNo);
                searchStudent(fp, rollNo);
                break;
            case 4: printf("Exiting...\n"); break;
            default: printf("Invalid choice!\n");
        }
    } while (choice != 4);

    fclose(fp);
    return 0;
}
